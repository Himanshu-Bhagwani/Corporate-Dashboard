# ─── SODA Business Platform — Environment Variables ───────────────────────────
# Copy this file to .env and fill in all values before running in production.
# NEVER commit .env to source control.

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=dashboard_db
DB_USER=dashboard_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── JWT — CRITICAL: Generate strong random secrets before deploying ──────────
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_64_BYTE_HEX_STRING_HERE
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_64_BYTE_HEX_STRING_HERE

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.sodabusiness.in,https://www.sodabusiness.in
TRUST_PROXY=true              # set true if behind nginx / load balancer

# ─── Government API Integration ───────────────────────────────────────────────
# Option A: Sandbox.co.in aggregator (recommended for fast onboarding)
GOVT_API_PROVIDER=sandbox
SANDBOX_API_KEY=your_sandbox_api_key_here
SANDBOX_API_BASE=https://api.sandbox.co.in

# Option B: Direct government APIs (requires separate onboarding for each)
# GOVT_API_PROVIDER=direct
# GSTN_API_KEY=your_gstn_api_key
# GSTN_API_BASE=https://api.gst.gov.in
# PAN_API_KEY=your_pan_api_key
# PAN_API_BASE=https://your_pan_api_provider.com
# MCA_API_KEY=your_mca_api_key
# MCA_API_BASE=https://your_mca_api_provider.com

# ─── Tally Integration ────────────────────────────────────────────────────────
# Tally must be running with XML server enabled on this host:port
TALLY_HOST=127.0.0.1          # IP/hostname of machine running Tally
TALLY_PORT=9000               # Tally XML server port (default: 9000)
TALLY_TIMEOUT=30000           # Request timeout in milliseconds

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...          # or use ANTHROPIC_API_KEY for Claude
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (for compliance alerts, team invites, scheduled reports) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@sodabusiness.in
SMTP_PASS=your_app_password_here
FROM_EMAIL=SODA Business <noreply@sodabusiness.in>

# ─── File Storage ─────────────────────────────────────────────────────────────
# For document vault encryption
DOCUMENT_ENCRYPTION_KEY=GENERATE_32_BYTE_HEX_STRING_HERE
UPLOAD_MAX_SIZE_MB=20

# ─── Loan Engine ──────────────────────────────────────────────────────────────
LOAN_PARTNER_API_KEY=         # Leave blank to use rule-based eligibility scoring
LOAN_PARTNER_API_BASE=
